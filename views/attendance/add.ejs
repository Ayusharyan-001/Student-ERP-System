<!DOCTYPE html>
<html>

<head>

<title>Mark Attendance</title>

<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
rel="stylesheet">

<link
rel="stylesheet"
href="/css/style.css">

</head>

<body>

<div class="wrapper">

<%- include('../partials/sidebar') %>

<div class="content">

<div class="card shadow-sm border-0">

<div class="card-body">

<h2 class="mb-4">
Mark Attendance
</h2>

<form
action="/attendance/add"
method="POST">

<div class="mb-3">

<label>Student</label>

<select
name="student_id"
class="form-select"
required>

<% students.forEach(student=>{ %>

<option
value="<%= student.student_id %>">

<%= student.full_name %>

</option>

<% }) %>

</select>

</div>

<div class="mb-3">

<label>Date</label>

<input
type="date"
name="attendance_date"
class="form-control"
required>

</div>

<div class="mb-3">

<label>Status</label>

<select
name="status"
class="form-select">

<option>Present</option>

<option>Absent</option>

</select>

</div>

<button
class="btn btn-success">

Save Attendance

</button>

</form>

</div>

</div>

</div>

</div>

</body>

</html>