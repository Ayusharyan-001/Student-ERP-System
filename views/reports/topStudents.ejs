<!DOCTYPE html>
<html>

<head>

<title>Top Students</title>

<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
rel="stylesheet">

<link
rel="stylesheet"
href="/css/style.css">

</head>

<body>

<div class="wrapper">

<%- include('../partials/sidebar') %>

<div class="content">

<h2 class="mb-4">
🏆 Top Students Report
</h2>

<div class="card shadow-sm">

<div class="card-body">

<table class="table table-hover">

<thead>

<tr>

<th>Rank</th>
<th>Student</th>
<th>Average Marks</th>

</tr>

</thead>

<tbody>

<%
report.forEach((item,index)=>{
%>

<tr>

<td>
#<%= index + 1 %>
</td>

<td>
<%= item.full_name %>
</td>

<td>
<%= item.average_marks %>
</td>

</tr>

<%
})
%>

</tbody>

</table>

</div>

</div>

</div>

</div>

</body>

</html>