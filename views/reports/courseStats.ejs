<!DOCTYPE html>
<html>

<head>

<title>Course Statistics</title>

<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
rel="stylesheet">

<link
rel="stylesheet"
href="/css/style.css">

</head>

<body>

<div class="wrapper">

<%- include('../partials/sidebar') %>

<div class="content">

<h2 class="mb-4">
📚 Course Statistics
</h2>

<div class="card shadow-sm">

<div class="card-body">

<table class="table table-hover">

<thead>

<tr>

<th>Course</th>
<th>Total Students</th>

</tr>

</thead>

<tbody>

<%
report.forEach(item=>{
%>

<tr>

<td>
<%= item.course_name %>
</td>

<td>
<%= item.total_students %>
</td>

</tr>

<%
})
%>

</tbody>

</table>

</div>

</div>

</div>

</div>

</body>

</html>