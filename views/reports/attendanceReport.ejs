<!DOCTYPE html>
<html>

<head>

<title>Attendance Report</title>

<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
rel="stylesheet">

<link
rel="stylesheet"
href="/css/style.css">

</head>

<body>

<div class="wrapper">

<%- include('../partials/sidebar') %>

<div class="content">

<h2 class="mb-4">
Attendance Report
</h2>

<div class="card shadow-sm">

<div class="card-body">

<table
class="table table-hover">

<thead>

<tr>

<th>Student</th>
<th>Attendance %</th>

</tr>

</thead>

<tbody>

<%
report.forEach(item=>{
%>

<tr>

<td>
<%= item.full_name %>
</td>

<td>
<%= item.attendance_percentage %>%
</td>

</tr>

<%
})
%>

</tbody>

</table>

</div>

</div>

</div>

</div>

</body>

</html>