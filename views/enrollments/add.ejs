<!DOCTYPE html>
<html>

<head>

<title>Assign Course</title>

<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
rel="stylesheet">

<link
rel="stylesheet"
href="/css/style.css">

</head>

<body>

<div class="wrapper">

<%- include('../partials/sidebar') %>

<div class="content">

<div class="card shadow-sm border-0">

<div class="card-body">

<h2 class="mb-4">
Assign Course
</h2>

<form
action="/enrollments/add"
method="POST"
>

<div class="mb-3">

<label>
Student
</label>

<select
name="student_id"
class="form-select"
required
>

<%
students.forEach(student=>{
%>

<option
value="<%= student.student_id %>">

<%= student.full_name %>

</option>

<%
})
%>

</select>

</div>

<div class="mb-3">

<label>
Course
</label>

<select
name="course_id"
class="form-select"
required
>

<%
courses.forEach(course=>{
%>

<option
value="<%= course.course_id %>">

<%= course.course_name %>

</option>

<%
})
%>

</select>

</div>

<button
class="btn btn-success">

Assign Course

</button>

</form>

</div>

</div>

</div>

</div>

</body>

</html>