<!DOCTYPE html>
<html>

<head>

<title>Enrollments</title>

<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
rel="stylesheet">

<link
rel="stylesheet"
href="/css/style.css">

</head>

<body>

<div class="wrapper">

<%- include('../partials/sidebar') %>

<div class="content">

<div
class="d-flex justify-content-between align-items-center mb-4">

<div>

<h2 class="fw-bold">
Enrollments
</h2>

<p class="text-muted">
Manage student course assignments
</p>

</div>

<a
href="/enrollments/add"
class="btn btn-primary rounded-pill">

Assign Course

</a>

</div>

<div class="card shadow-sm border-0">

<div class="card-body">

<table
class="table table-hover">

<thead>

<tr>

<th>ID</th>
<th>Student</th>
<th>Course</th>

</tr>

</thead>

<tbody>

<%
enrollments.forEach(item=>{
%>

<tr>

<td>
<%= item.enrollment_id %>
</td>

<td>
<%= item.full_name %>
</td>

<td>
<%= item.course_name %>
</td>

</tr>

<%
})
%>

</tbody>

</table>

</div>

</div>

</div>

</div>

</body>

</html>