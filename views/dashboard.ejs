<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Student ERP</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    />

    <link rel="stylesheet" href="/css/style.css" />
  </head>

  <body>
    <div class="wrapper">
      <div class="sidebar">
        <h3>
          <i class="fa-solid fa-graduation-cap"></i>
          Student ERP
        </h3>

        <ul>
          <li>
            <a href="/"> Dashboard </a>
          </li>

          <li>
            <a href="/students">
              <i class="fa-solid fa-user-graduate"></i>
              Students
            </a>
          </li>

          <li>
            <a href="/courses">
              <i class="fa-solid fa-book"></i>
              Courses
            </a>
          </li>

          <li>
            <a href="/attendance">
              <i class="fa-solid fa-calendar-check"></i>
              Attendance
            </a>
          </li>

          <li>
            <a href="/enrollments">
              <i class="fa-solid fa-calendar-check"></i>
              Enrollments
            </a>
          </li>

          <li>
            <a href="/results">
              <i class="fa-solid fa-square-poll-vertical"></i>
              Results
            </a>
          </li>
        </ul>
      </div>

      <div class="main-content">
        <div class="welcome-card mb-4">
          <h3>Welcome Back, Ayush 👋</h3>

          <p>
            Manage students, attendance, courses and results from one place.
          </p>
        </div>

        <h2 class="mb-4 fw-bold">Dashboard Overview</h2>

        <div class="row">
          <div class="col-lg-3 col-md-6">
            <div class="card stat-card">
              <div class="card-body">
                <h6>
                  <i class="fa-solid fa-user-graduate"></i> Total Students
                </h6>

                <h2><%= totalStudents %></h2>
              </div>
            </div>
          </div>

          <div class="col-md-3">
            <div class="card stat-card">
              <div class="card-body">
                <h6><i class="fa-solid fa-book"></i> Total Courses</h6>

                <h2><%= totalCourses %></h2>
              </div>
            </div>
          </div>

          <div class="col-md-3">
            <div class="card stat-card">
              <div class="card-body">
                <h6>
                  <i class="fa-solid fa-link"></i>
                  Total Enrollments
                </h6>

                <h2><%= totalEnrollments %></h2>
              </div>
            </div>
          </div>

          <div class="col-md-3">
            <div class="card stat-card">
              <div class="card-body">
                <h6>
                  <i class="fa-solid fa-link"></i>
                  Attendance
                </h6>

                <h2><%= attendanceCount %></h2>
              </div>
            </div>
          </div>

          <div class="col-md-3">
            <div class="card stat-card">
              <div class="card-body">
                <h6><i class="fa-solid fa-chart-line"></i> Results</h6>

                <h2><%= totalResults %></h2>
              </div>
            </div>
          </div>
        </div>
        <div class="row mt-4">
          <div class="col-md-4">
            <a href="/students" class="btn btn-outline-primary w-100">
              Manage Students
            </a>
          </div>

          <div class="col-md-4">
            <a href="/courses" class="btn btn-outline-success w-100">
              Manage Courses
            </a>
          </div>

          <div class="col-md-4">
            <a href="/enrollments" class="btn btn-outline-dark w-100">
              Manage Enrollments
            </a>
          </div>
          <div class="row mt-4">
            <div class="col-md-6">
              <div class="card shadow-sm border-0">
                <div class="card-body">
                  <h5>🏆 Top Performer</h5>

                  <p class="mb-0">
                    <%= topPerformer ? topPerformer.full_name : 'No Data' %>
                  </p>

                  <p class="text-muted">
                    Average Marks: <%= topPerformer ? topPerformer.avg_marks : 0 %>
                  </p>
                </div>
              </div>
            </div>
          </div>
          <div class="row mt-4">

<div class="col-md-6">

<div class="card shadow-sm border-0">

<div class="card-body">

<h5>
Quick Reports
</h5>

<div class="d-grid gap-2">

<a
href="/reports/attendance"
class="btn btn-outline-primary">

Attendance Report

</a>

<a
href="/reports/top-students"
class="btn btn-outline-success">

Top Students

</a>

<a
href="/reports/course-stats"
class="btn btn-outline-dark">

Course Statistics

</a>

</div>

</div>

</div>

</div>
<div class="card shadow-sm mt-4">
    <div class="card-body">

        <h5 class="mb-3">
            ERP Analytics
        </h5>

        <canvas id="erpChart"></canvas>

    </div>
</div>


</div>

        </div>
      </div>
    </div>


    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>

const ctx = document.getElementById('erpChart');

new Chart(ctx, {

    type: 'bar',

    data: {

        labels: [
            'Students',
            'Courses',
            'Enrollments',
            'Attendance',
            'Results'
        ],

        datasets: [{

            label: 'ERP Statistics',

           data: [
    Number("<%= totalStudents %>"),
    Number("<%= totalCourses %>"),
    Number("<%= totalEnrollments %>"),
    Number("<%= attendanceCount %>"),
    Number("<%= totalResults %>")
]

        }]

    },

    options: {

        responsive: true,

        plugins: {

            legend: {
                display: true
            }

        }

    }

});

</script>

<%- include("./partials/footer") %>
  </body>
</html>
